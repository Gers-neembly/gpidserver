<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="info"
      internalLogFile="c:\temp\GameEngine-BO-api.txt"
      throwConfigExceptions="true">

  <!-- enable asp.net core layout renderers -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
    <add assembly="Sentry.NLog" />
  </extensions>

  <!-- the targets to write to -->
  <targets async="true">
    <!-- another file log, only own logs. Uses some ASP.NET core renderers -->

    <target xsi:type="File"
          name="ownFile-web"
          fileName="${basedir}/logs/pp-auth-logs.log"
          archiveFileName="${basedir}/archives/pp-auth-log.${shortdate}.zip"
          archiveEvery="Day"
          archiveNumbering="Rolling"
          archiveAboveSize="2097152"
          concurrentWrites="true"
          keepFileOpen="false"
          enableArchiveFileCompression="true"
          maxArchiveDays="31"
          layout="${longdate}|${event-properties:item=EventId_Id}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />

    <target xsi:type="Sentry" name="sentry"
        dsn="https://b67017e48e56496e9c8da173452cb540@o344011.ingest.sentry.io/5430379"
        layout="${message} | ${exception:format=tostring}"
        breadcrumbLayout="${message}"
        minimumBreadcrumbLevel="Error"
        minimumEventLevel="Error">

      <!-- Advanced options can be configured here-->
      <options
          environment="Development"
          attachStacktrace="true"
          sendDefaultPii="true"
          shutdownTimeoutSeconds="5"
          includeEventDataOnBreadcrumbs="true"
       />
      
    </target>
   
  </targets>

  <!-- rules to map from logger name to target -->
  <rules>
    <!--Skip non-critical Microsoft logs and so log only own logs-->
    <logger name="*" minlevel="Trace" writeTo="ownFile-web" />
    <logger name="*" writeTo="sentry" />
  </rules>
</nlog>
