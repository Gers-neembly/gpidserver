<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="info"
      internalLogFile="c:\temp\GameEngine-BO-api.txt"
      throwConfigExceptions="true">

  <!-- enable asp.net core layout renderers -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>
  <extensions>
    <add assembly="NLog.MailKit"/>
  </extensions>

  <!-- the targets to write to -->
  <targets async="true">
    <!-- another file log, only own logs. Uses some ASP.NET core renderers -->
    <target xsi:type="File"
          name="ownFile-web"
          fileName="c:\temp\nlogger-own-${shortdate}.log"
          layout="${longdate}|${event-properties:item=EventId_Id}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />

    <target xsi:type="Mail"
          name="mail"
          layout="${longdate} |${event-properties:item=EventId_Id} | ${uppercase:${level}‌} | ${logger} | ${message} ${exception:format=tostring} | url: ${aspnet-request-url} | action: ${aspnet-mvc-action}"
          html="false"
          replaceNewlineWithBrTagInHtml="false"
          subject="BackOffice API Logs ${longdate} (GMT+8)"
          to="logs.dev@neembly.com"
          from="log.sender@neembly.io"
          smtpUserName="log.sender@neembly.io"
          enableSsl="true"
          smtpPassword="Wasd2017!"
          smtpAuthentication="Basic"
          smtpServer="smtp.zoho.com"
          smtpPort="465"
          skipCertificateValidation="true"/>
  </targets>

  <!-- rules to map from logger name to target -->
  <rules>
    <!--Skip non-critical Microsoft logs and so log only own logs-->
    <logger name="*" minlevel="Error" maxlevel="Error" writeTo="mail" />
    <logger name="*" minlevel="Trace" writeTo="ownFile-web" />
  </rules>
</nlog>
